{
  "manifest_version": 3,
  "name": "Markdown Viewer Plus",
  "version": "1.2.0",
  "description": "打开本地 .md 文件即自动渲染：代码高亮、表格、任务列表、脚注、数学公式、Mermaid 图表、目录、深色模式。",
  "permissions": ["storage"],
  "host_permissions": ["file:///*"],
  "background": {
    "service_worker": "bg.js"
  },
  "content_scripts": [
    {
      "matches": ["file:///*"],
      "include_globs": [
        "*.md",
        "*.markdown",
        "*.mdown",
        "*.mkd",
        "*.mdwn"
      ],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["katex/*"],
      "matches": ["file:///*"]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Markdown Viewer Plus"
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
